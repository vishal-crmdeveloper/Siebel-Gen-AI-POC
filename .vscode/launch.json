{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "▶️ Run Streamlit UI",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/streamlit_app.py"
            ],
            "justMyCode": true
        },
        {
            "name": "▶️ Run FastAPI Backend",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "justMyCode": true
        }
    ],
    "compounds": [
        {
            "name": "🚀 Run Both (Backend + UI)",
            "configurations": [
                "▶️ Run FastAPI Backend",
                "▶️ Run Streamlit UI"
            ],
            "stopAll": true
        }
    ]
}
